{
  "id": "guest_wifi",
  "name": "Guest WiFi",
  "version": "1.0.0",
  "description": "Display guest WiFi credentials on your board",
  "author": "FiestaBoard Team",
  "repository": "https://github.com/Fiestaboard/fiestaboard-plugin--guest-wifi",
  "documentation": "README.md",
  "icon": "wifi",
  "category": "utility",
  "settings_schema": {
    "type": "object",
    "properties": {
      "enabled": {
        "type": "boolean",
        "title": "Enable Guest WiFi",
        "default": false
      },
      "ssid": {
        "type": "string",
        "title": "Network Name (SSID)",
        "description": "Your guest WiFi network name",
        "maxLength": 22
      },
      "password": {
        "type": "string",
        "title": "Password",
        "description": "Your guest WiFi password",
        "maxLength": 22,
        "ui:widget": "password"
      }
    },
    "required": [
      "ssid",
      "password"
    ]
  },
  "env_vars": [
    {
      "name": "GUEST_WIFI_SSID",
      "required": true,
      "description": "Guest WiFi network name"
    },
    {
      "name": "GUEST_WIFI_PASSWORD",
      "required": true,
      "description": "Guest WiFi password"
    }
  ],
  "variables": {
    "groups": {
      "credentials": {
        "label": "WiFi Credentials"
      }
    },
    "simple": {
      "ssid": {
        "description": "Guest WiFi network name (SSID)",
        "type": "string",
        "max_length": 22,
        "group": "credentials",
        "example": "MyGuestNetwork"
      },
      "password": {
        "description": "Guest WiFi password",
        "type": "string",
        "max_length": 22,
        "group": "credentials",
        "example": "welcome123"
      }
    }
  },
  "fiestaboard_version": ">=2.10.0",
  "screenshots": [
    {
      "src": "docs/board-display.png",
      "alt": "Guest WiFi displayed on a Vestaboard",
      "caption": "Display guest WiFi credentials on your board",
      "primary": true
    }
  ]
}
